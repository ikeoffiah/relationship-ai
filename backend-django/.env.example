# Database (Supabase for prod, local postgres for dev)
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Redis (Upstash for prod, local redis for dev)
REDIS_URL=redis://localhost:6379/0

# Vector DB (pgvector via Supabase — same DATABASE_URL)
# No separate vector DB service needed for MVP

# LLM
ANTHROPIC_API_KEY=sk-ant-...

# Encryption (single master secret — replaces AWS KMS for MVP)
# 32-byte hex secret, generated once, stored in Railway env
ENCRYPTION_MASTER_SECRET=

# App
SECRET_KEY=
DEBUG=false
ALLOWED_HOSTS=your-service.up.railway.app

# Monitoring
SENTRY_DSN=
