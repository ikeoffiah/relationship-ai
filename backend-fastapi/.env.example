# Database (Local Docker Postgres)
DATABASE_URL=postgresql://postgres:localdevonly@postgres:5432/postgres

# Redis (Local Docker Redis)
REDIS_URL=redis://redis:6379/0

# LLM
ANTHROPIC_API_KEY=sk-ant-...

# Encryption
ENCRYPTION_MASTER_SECRET=your_32_byte_hex_secret_here

# App
SECRET_KEY=fastapi-secret-key-here
DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1,postgres,fastapi

# Monitoring
SENTRY_DSN=
